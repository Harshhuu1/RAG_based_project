FROM python:3.11-slim

WORKDIR /mlflow
RUN mkdir -p /mlflow/artifacts

RUN pip install --no-cache-dir mlflow==2.13.0

EXPOSE 5000

CMD ["mlflow", "server", \
     "--host", "0.0.0.0", \
     "--port", "5000", \
"--backend-store-uri", "sqlite:////mlflow/mlflow.db", \
     "--default-artifact-root", "/mlflow/artifacts"]